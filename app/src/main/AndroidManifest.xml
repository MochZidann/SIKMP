<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:name=".KoperasiApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/logo_sikmp"
        android:label="@string/app_name"
        android:roundIcon="@drawable/logo_sikmp"
        android:supportsRtl="true"
        android:theme="@style/Theme.SIKMP">

        <activity
            android:name=".ui.SplashActivity"
            android:exported="true"
            android:screenOrientation="sensorLandscape"
            android:theme="@style/Theme.SIKMP.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".ui.LoginActivity"
            android:screenOrientation="sensorLandscape"
            android:windowSoftInputMode="adjustResize"
            android:exported="false" />
        <activity
            android:name=".ui.DashboardActivity"
            android:screenOrientation="sensorLandscape"
            android:exported="false"
            android:theme="@style/Theme.SIKMP.NoActionBar" />
        <activity
            android:name=".ui.UserManagementActivity"
            android:screenOrientation="sensorLandscape"
            android:exported="false"
            android:theme="@style/Theme.SIKMP.NoActionBar" />
        <activity
            android:name=".ui.MemberManagementActivity"
            android:screenOrientation="sensorLandscape"
            android:exported="false"
            android:theme="@style/Theme.SIKMP.NoActionBar" />
        <activity
            android:name=".ui.SettingsActivity"
            android:screenOrientation="sensorLandscape"
            android:exported="false"
            android:theme="@style/Theme.SIKMP.NoActionBar" />
        <activity
            android:name=".ui.BackupRestoreActivity"
            android:screenOrientation="sensorLandscape"
            android:exported="false"
            android:theme="@style/Theme.SIKMP.NoActionBar" />
        <activity
            android:name=".ui.ProductManagementActivity"
            android:screenOrientation="sensorLandscape"
            android:exported="false"
            android:theme="@style/Theme.SIKMP.NoActionBar" />
        <activity
            android:name=".ui.StockManagementActivity"
            android:screenOrientation="sensorLandscape"
            android:exported="false"
            android:theme="@style/Theme.SIKMP.NoActionBar" />
        <activity
            android:name=".ui.PosActivity"
            android:screenOrientation="sensorLandscape"
            android:windowSoftInputMode="adjustResize"
            android:exported="false"
            android:theme="@style/Theme.SIKMP.NoActionBar" />
        <activity
            android:name=".ui.ReportsActivity"
            android:screenOrientation="sensorLandscape"
            android:exported="false"
            android:theme="@style/Theme.SIKMP.NoActionBar" />
        <activity
            android:name=".ui.AuditTrailActivity"
            android:screenOrientation="sensorLandscape"
            android:exported="false"
            android:theme="@style/Theme.SIKMP.NoActionBar" />
        <activity
            android:name=".ui.admin_gudang.AdminGudangActivity"
            android:screenOrientation="sensorLandscape"
            android:exported="false"
            android:theme="@style/Theme.SIKMP.NoActionBar" />
        <activity
            android:name=".ui.owner.OwnerStockReportActivity"
            android:screenOrientation="sensorLandscape"
            android:exported="false"
            android:theme="@style/Theme.SIKMP.NoActionBar" />

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>

</manifest>
