<?xml version="1.0" encoding="utf-8"?>

<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"

    xmlns:app="http://schemas.android.com/apk/res-auto"

    android:layout_width="match_parent"

    android:layout_height="match_parent"

    android:background="#F8FAFC">



    <LinearLayout

        android:layout_width="match_parent"

        android:layout_height="wrap_content"

        android:orientation="vertical"

        android:padding="20dp">



        <!-- Header -->

        <TextView

            android:layout_width="wrap_content"

            android:layout_height="wrap_content"

            android:text="Kesehatan Inventori"

            android:textColor="#1E293B"

            android:textSize="22sp"

            android:textStyle="bold"

            android:layout_marginBottom="4dp" />

        <TextView

            android:layout_width="wrap_content"

            android:layout_height="wrap_content"

            android:text="Nilai aset stok sebagai kapital bisnis"

            android:textColor="#94A3B8"

            android:textSize="12sp"

            android:layout_marginBottom="20dp" />



        <!-- Asset Value Cards -->

        <LinearLayout

            android:layout_width="match_parent"

            android:layout_height="wrap_content"

            android:orientation="horizontal"

            android:layout_marginBottom="12dp">



            <com.google.android.material.card.MaterialCardView

                android:layout_width="0dp"

                android:layout_height="110dp"

                android:layout_weight="1"

                app:cardCornerRadius="16dp"

                app:cardElevation="2dp">

                <LinearLayout

                    android:layout_width="match_parent"

                    android:layout_height="match_parent"

                    android:orientation="vertical"

                    android:padding="16dp"

                    android:background="#EFF6FF">

                    <TextView

                        android:layout_width="wrap_content"

                        android:layout_height="wrap_content"

                        android:text="TOTAL NILAI ASET"

                        android:textColor="#1D4ED8"

                        android:textSize="10sp"

                        android:textStyle="bold" />

                    <TextView

                        android:id="@+id/txtTotalAsset"

                        android:layout_width="wrap_content"

                        android:layout_height="wrap_content"

                        android:text="Rp 0"

                        android:textColor="#1E3A8A"

                        android:textSize="22sp"

                        android:textStyle="bold"

                        android:layout_marginTop="8dp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>



            <View android:layout_width="12dp" android:layout_height="0dp" />



            <com.google.android.material.card.MaterialCardView

                android:layout_width="0dp"

                android:layout_height="110dp"

                android:layout_weight="1"

                app:cardCornerRadius="16dp"

                app:cardElevation="2dp">

                <LinearLayout

                    android:layout_width="match_parent"

                    android:layout_height="match_parent"

                    android:orientation="vertical"

                    android:padding="16dp"

                    android:background="#F0FDF4">

                    <TextView

                        android:layout_width="wrap_content"

                        android:layout_height="wrap_content"

                        android:text="TOTAL SKU AKTIF"

                        android:textColor="#15803D"

                        android:textSize="10sp"

                        android:textStyle="bold" />

                    <TextView

                        android:id="@+id/txtTotalSku"

                        android:layout_width="wrap_content"

                        android:layout_height="wrap_content"

                        android:text="0"

                        android:textColor="#14532D"

                        android:textSize="22sp"

                        android:textStyle="bold"

                        android:layout_marginTop="8dp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>



        <LinearLayout

            android:layout_width="match_parent"

            android:layout_height="wrap_content"

            android:orientation="horizontal"

            android:layout_marginBottom="24dp">



            <com.google.android.material.card.MaterialCardView

                android:layout_width="0dp"

                android:layout_height="110dp"

                android:layout_weight="1"

                app:cardCornerRadius="16dp"

                app:cardElevation="2dp">

                <LinearLayout

                    android:layout_width="match_parent"

                    android:layout_height="match_parent"

                    android:orientation="vertical"

                    android:padding="16dp"

                    android:background="#FEF2F2">

                    <TextView

                        android:layout_width="wrap_content"

                        android:layout_height="wrap_content"

                        android:text="STOK RENDAH (KRITIS)"

                        android:textColor="#DC2626"

                        android:textSize="10sp"

                        android:textStyle="bold" />

                    <TextView

                        android:id="@+id/txtLowStockCount"

                        android:layout_width="wrap_content"

                        android:layout_height="wrap_content"

                        android:text="0"

                        android:textColor="#7F1D1D"

                        android:textSize="22sp"

                        android:textStyle="bold"

                        android:layout_marginTop="8dp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>



            <View android:layout_width="12dp" android:layout_height="0dp" />



            <com.google.android.material.card.MaterialCardView

                android:layout_width="0dp"

                android:layout_height="110dp"

                android:layout_weight="1"

                app:cardCornerRadius="16dp"

                app:cardElevation="2dp">

                <LinearLayout

                    android:layout_width="match_parent"

                    android:layout_height="match_parent"

                    android:orientation="vertical"

                    android:padding="16dp"

                    android:background="#FFF7ED">

                    <TextView

                        android:layout_width="wrap_content"

                        android:layout_height="wrap_content"

                        android:text="DEAD STOCK"

                        android:textColor="#C2410C"

                        android:textSize="10sp"

                        android:textStyle="bold" />

                    <TextView

                        android:id="@+id/txtDeadStockCount"

                        android:layout_width="wrap_content"

                        android:layout_height="wrap_content"

                        android:text="0"

                        android:textColor="#7C2D12"

                        android:textSize="22sp"

                        android:textStyle="bold"

                        android:layout_marginTop="8dp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>



        <!-- Nilai Aset per Kategori -->

        <TextView

            android:layout_width="wrap_content"

            android:layout_height="wrap_content"

            android:text="Nilai Aset per Kategori"

            android:textColor="#1E293B"

            android:textSize="16sp"

            android:textStyle="bold"

            android:layout_marginBottom="8dp" />



        <com.google.android.material.card.MaterialCardView

            android:layout_width="match_parent"

            android:layout_height="wrap_content"

            android:layout_marginBottom="24dp"

            app:cardCornerRadius="16dp"

            app:cardElevation="2dp">

            <LinearLayout

                android:layout_width="match_parent"

                android:layout_height="wrap_content"

                android:orientation="vertical">

                <LinearLayout

                    android:layout_width="match_parent"

                    android:layout_height="wrap_content"

                    android:orientation="horizontal"

                    android:paddingHorizontal="16dp"

                    android:paddingVertical="10dp"

                    android:background="#F1F5F9">

                    <TextView

                        android:layout_width="0dp"

                        android:layout_height="wrap_content"

                        android:layout_weight="1"

                        android:text="Kategori"

                        android:textColor="#64748B"

                        android:textSize="11sp"

                        android:textStyle="bold" />

                    <TextView

                        android:layout_width="50dp"

                        android:layout_height="wrap_content"

                        android:gravity="center"

                        android:text="SKU"

                        android:textColor="#64748B"

                        android:textSize="11sp"

                        android:textStyle="bold" />

                    <TextView

                        android:layout_width="100dp"

                        android:layout_height="wrap_content"

                        android:gravity="end"

                        android:text="Nilai Aset"

                        android:textColor="#64748B"

                        android:textSize="11sp"

                        android:textStyle="bold" />

                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView

                    android:id="@+id/recyclerCategoryAsset"

                    android:layout_width="match_parent"

                    android:layout_height="wrap_content"

                    android:nestedScrollingEnabled="false" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>



        <!-- Dead Stock List -->

        <TextView

            android:layout_width="wrap_content"

            android:layout_height="wrap_content"

            android:text="Produk Tidak Laku (30 Hari Terakhir)"

            android:textColor="#1E293B"

            android:textSize="16sp"

            android:textStyle="bold"

            android:layout_marginBottom="8dp" />



        <com.google.android.material.card.MaterialCardView

            android:layout_width="match_parent"

            android:layout_height="wrap_content"

            android:layout_marginBottom="24dp"

            app:cardCornerRadius="16dp"

            app:cardElevation="2dp">

            <LinearLayout

                android:layout_width="match_parent"

                android:layout_height="wrap_content"

                android:orientation="vertical">

                <LinearLayout

                    android:layout_width="match_parent"

                    android:layout_height="wrap_content"

                    android:orientation="horizontal"

                    android:paddingHorizontal="16dp"

                    android:paddingVertical="10dp"

                    android:background="#F1F5F9">

                    <TextView

                        android:layout_width="0dp"

                        android:layout_height="wrap_content"

                        android:layout_weight="1"

                        android:text="Nama Produk"

                        android:textColor="#64748B"

                        android:textSize="11sp"

                        android:textStyle="bold" />

                    <TextView

                        android:layout_width="80dp"

                        android:layout_height="wrap_content"

                        android:gravity="center"

                        android:text="Kategori"

                        android:textColor="#64748B"

                        android:textSize="11sp"

                        android:textStyle="bold" />

                    <TextView

                        android:layout_width="60dp"

                        android:layout_height="wrap_content"

                        android:gravity="end"

                        android:text="Stok"

                        android:textColor="#64748B"

                        android:textSize="11sp"

                        android:textStyle="bold" />

                    <TextView

                        android:layout_width="80dp"

                        android:layout_height="wrap_content"

                        android:gravity="end"

                        android:text="Nilai (Rp)"

                        android:textColor="#64748B"

                        android:textSize="11sp"

                        android:textStyle="bold" />

                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView

                    android:id="@+id/recyclerDeadStock"

                    android:layout_width="match_parent"

                    android:layout_height="wrap_content"

                    android:nestedScrollingEnabled="false" />

                <TextView

                    android:id="@+id/txtNoDeadStock"

                    android:layout_width="match_parent"

                    android:layout_height="wrap_content"

                    android:padding="24dp"

                    android:text="Semua produk telah terjual dalam 30 hari terakhir"

                    android:textColor="#94A3B8"

                    android:textSize="13sp"

                    android:gravity="center"

                    android:visibility="gone" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>



    </LinearLayout>

</androidx.core.widget.NestedScrollView>