<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:hint="Kode Promo (Contoh: HEMAT20)"
            app:startIconDrawable="@android:drawable/ic_menu_edit">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPromoCode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textCapCharacters" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:hint="Nama Promo"
            app:startIconDrawable="@android:drawable/ic_menu_info_details">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPromoName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:hint="Deskripsi Promo"
            app:startIconDrawable="@android:drawable/ic_menu_info_details">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPromoDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textMultiLine"
                android:minLines="2" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:hint="Diskon (%)"
            app:startIconDrawable="@android:drawable/ic_menu_send">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etDiscount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="Masa Berlaku Promo"
            android:textColor="@color/gray_800"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPromoDate"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="Pilih Tanggal"
                app:icon="@android:drawable/ic_menu_myplaces"
                app:strokeColor="@color/primary_red"
                android:textColor="@color/primary_red"
                app:iconTint="@color/primary_red" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPromoTime"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Pilih Waktu"
                app:icon="@android:drawable/ic_menu_recent_history"
                app:strokeColor="@color/primary_red"
                android:textColor="@color/primary_red"
                app:iconTint="@color/primary_red" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvPromoDateTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:gravity="center"
            android:text="Belum diatur"
            android:textColor="@color/gray_600" />

        <CheckBox
            android:id="@+id/cbIsActive"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Aktifkan promo segera"
            android:checked="true" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
