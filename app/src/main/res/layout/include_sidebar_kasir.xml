<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="240dp"
    android:layout_height="match_parent"
    android:background="@android:color/white"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/purple_500"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/sidebarTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Koperasi Merah Putih"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            android:textColor="@android:color/white" />

        <TextView
            android:id="@+id/sidebarSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Kasir"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textColor="@android:color/white" />
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/menuDashboard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Dashboard"
        app:icon="@android:drawable/ic_menu_view"
        app:iconGravity="textStart" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/menuPos"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Transaksi POS"
        app:icon="@android:drawable/ic_menu_add"
        app:iconGravity="textStart" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/menuReports"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Riwayat Penjualan"
        app:icon="@android:drawable/ic_menu_recent_history"
        app:iconGravity="textStart" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/menuProducts"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Lihat Barang"
        app:icon="@android:drawable/ic_menu_search"
        app:iconGravity="textStart" />

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/menuLogout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        android:text="Logout"
        app:icon="@android:drawable/ic_lock_power_off"
        app:iconGravity="textStart" />

</LinearLayout>
