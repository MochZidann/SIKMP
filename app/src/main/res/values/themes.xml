<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.SIKMP" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/accent_blue</item>
        <item name="colorPrimaryVariant">@color/accent_blue</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/accent_blue_light</item>
        <item name="colorSecondaryVariant">@color/accent_blue</item>
        <item name="colorOnSecondary">@color/black</item>

        <item name="android:statusBarColor">@color/accent_blue</item>
        <item name="android:navigationBarColor">@color/white</item>

        <!-- Global Tablet Font Sizes & Styles -->
        <item name="android:fontFamily">sans-serif-medium</item>

        <!-- Override Material Components TextAppearances for Tablet Scaling -->
        <item name="textAppearanceHeadline4">@style/TextAppearance.App.HeadlineLarge</item>
        <item name="textAppearanceHeadline5">@style/TextAppearance.App.HeadlineMedium</item>
        <item name="textAppearanceHeadline6">@style/TextAppearance.App.TitleLarge</item>
        <item name="textAppearanceBody1">@style/TextAppearance.App.BodyLarge</item>
    </style>

    <style name="Theme.SIKMP.NoActionBar" parent="Theme.SIKMP">
    </style>

    <!-- Headline Large (Dashboard Title) -->
    <style name="TextAppearance.App.HeadlineLarge" parent="TextAppearance.MaterialComponents.Headline3">
        <item name="android:textSize">48sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <!-- Headline Medium (Sub-menu Title) -->
    <style name="TextAppearance.App.HeadlineMedium" parent="TextAppearance.MaterialComponents.Headline5">
        <item name="android:textSize">32sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <!-- Title Large (Card Titles) -->
    <style name="TextAppearance.App.TitleLarge" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textSize">24sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/gray_800</item>
    </style>

    <!-- Body Large (List Text) -->
    <style name="TextAppearance.App.BodyLarge" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textSize">18sp</item>
        <item name="android:textColor">@color/gray_800</item>
    </style>

    <style name="Widget.App.Button" parent="Widget.MaterialComponents.Button">
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.App.SmallComponent</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:paddingTop">20dp</item>
        <item name="android:paddingBottom">20dp</item>
        <item name="android:textSize">18sp</item>
    </style>

    <style name="ShapeAppearance.App.SmallComponent" parent="ShapeAppearance.MaterialComponents.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

    <!-- Tab Layout Appearance for Tablet -->
    <style name="CustomTabTextAppearance" parent="TextAppearance.Design.Tab">
        <item name="android:textSize">18sp</item>
        <item name="android:fontFamily">sans-serif-black</item>
        <item name="android:textAllCaps">true</item>
    </style>
</resources>